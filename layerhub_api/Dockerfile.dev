FROM ruby:3.4-slim

# Install system dependencies
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
    build-essential libpq-dev git curl libyaml-dev \
    wget ca-certificates libgl1 libglu1-mesa libglib2.0-0 libgtk-3-0 libdbus-1-3 libegl1 && \
    rm -rf /var/lib/apt/lists/*

# Install PrusaSlicer CLI (2.6.1 — no webkit dependency, works headless)
RUN wget -q "https://github.com/prusa3d/PrusaSlicer/releases/download/version_2.6.1/PrusaSlicer-2.6.1+linux-x64-GTK3-202309060711.AppImage" \
      -O /tmp/prusaslicer.AppImage && \
    chmod +x /tmp/prusaslicer.AppImage && \
    cd /tmp && ./prusaslicer.AppImage --appimage-extract && \
    mv /tmp/squashfs-root /opt/prusaslicer && \
    rm /tmp/prusaslicer.AppImage && \
    printf '#!/bin/bash\nexport LD_LIBRARY_PATH=/opt/prusaslicer/usr/lib:$LD_LIBRARY_PATH\nexec /opt/prusaslicer/usr/bin/prusa-slicer "$@"\n' > /usr/local/bin/prusa-slicer && \
    chmod +x /usr/local/bin/prusa-slicer

WORKDIR /app

# Install gems (cached layer)
COPY Gemfile Gemfile.lock ./
RUN bundle install

# Copy app code
COPY . .

EXPOSE 3000

CMD ["rails", "server", "-b", "0.0.0.0"]
