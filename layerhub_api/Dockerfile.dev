FROM ruby:3.4-slim

# Install system dependencies
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
    build-essential libpq-dev git curl libyaml-dev \
    wget ca-certificates libgl1 libglu1-mesa libglib2.0-0 libgtk-3-0 libdbus-1-3 libegl1 \
    libsm6 libxext6 libxrender1 libx11-6 libice6 libxcb1 libfontconfig1 libfreetype6 \
    libwayland-client0 libwayland-egl1 libwebkit2gtk-4.1-0 xvfb xauth libmspack0 \
    libgstreamer1.0-0 libgstreamer-plugins-base1.0-0 libsoup-3.0-0 && \
    rm -rf /var/lib/apt/lists/*

# Install OrcaSlicer CLI (2.3.2 — supports STL, 3MF, STEP)
RUN set -e && \
    wget -q "https://github.com/OrcaSlicer/OrcaSlicer/releases/download/v2.3.2/OrcaSlicer_Linux_AppImage_Ubuntu2404_V2.3.2.AppImage" \
      -O /tmp/orcaslicer.AppImage && \
    chmod +x /tmp/orcaslicer.AppImage && \
    cd /tmp && ./orcaslicer.AppImage --appimage-extract && \
    test -d /tmp/squashfs-root && \
    mv /tmp/squashfs-root /opt/orcaslicer && \
    test -f /opt/orcaslicer/bin/orca-slicer && \
    rm /tmp/orcaslicer.AppImage

COPY orca-slicer-wrapper.sh /usr/local/bin/orca-slicer
RUN chmod +x /usr/local/bin/orca-slicer

WORKDIR /app

# Install gems (cached layer)
COPY Gemfile Gemfile.lock ./
RUN bundle install

# Copy app code
COPY . .

EXPOSE 3000

CMD ["rails", "server", "-b", "0.0.0.0"]
